[Unit]
Description=Shreya Music Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/Shreyaxmusic
Environment="PATH=/root/Shreyaxmusic/.venv/bin:/root/.deno/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
ExecStart=/root/Shreyaxmusic/.venv/bin/python3 -m shreya
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
